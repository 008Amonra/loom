      "position": [
        0,
        300
      ],
      "webhookId": "chat",
      "path": "chat",
      "httpMethod": "POST",
      "responseMode": "lastNode",
      "options": {}
    },
    {
      "parameters": {
        "url": "={{ $env.CHAT_API_URL || 'https://openrouter.ai/api/v1/chat/completions' }}",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.CHAT_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "options": {},
        "method": "POST",
        "bodyType": "json",
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "={{ $env.CHAT_MODEL || 'gpt-4o-mini' }}"
            },
            {
              "name": "messages",
              "value": "={{ [{\"role\": \"system\", \"content\": \"You are Big Pickle, the 45dgof8 AI assistant. You are helpful, concise, and practical.\"}, {\"role\": \"user\", \"content\": $json.body.message}] }}"
            },
            {
              "name": "max_tokens",
              "value": 1024
            }
          ]
        }
      },
      "id": "3c21f0cf-c874-4400-9566-7abb6c8a3bf7",
      "name": "Ask AI",
      "type": "n8n-nodes-base.httpRequest",
